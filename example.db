Domain {
   Filename = "single_sphere.raw"
   ReadType = "8Bit"
   N = 8, 8, 8            // domain size
   n = 8, 8, 8
   nproc = 1, 1, 1
   VoxelLabels = 0, 1, 2    // solid, expelled, injected
   ReadValues = 0, 1
   WriteValues = 0, 1
   voxel_length = 1
   BC = 0
}

FM {
   Diameters = 1, 50, 1         //start, end, step
   ImageRoot = "d0"             // name files
   ImageDir = "d0"              // folder in which data is saved
   SaveImage = true
   Direction = 0, 0, 1          // axis of intrusion (accepts negative values)
   protocol = "drainage"
}
